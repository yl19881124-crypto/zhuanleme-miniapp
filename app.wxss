page {
  background: #f5f6f8;
  color: #1a1a1a;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border: 1px solid #e9edf3;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(17, 17, 17, 0.04);
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.subtle {
  color: #7d7d7d;
  font-size: 24rpx;
}

.accent {
  color: #e0a800;
}

.btn-primary,
.btn-secondary {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  padding: 0 20rpx;
}

.btn-primary {
  background: #111111;
  color: #ffffff;
  border: 1px solid #111111;
}

.btn-secondary {
  background: #ffffff;
  color: #111111;
  border: 1px solid #d6dbe3;
}

.input,
.picker,
.popup-input {
  width: 100%;
  background: #f7f8fa;
  border: 1px solid #e1e6ef;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}
