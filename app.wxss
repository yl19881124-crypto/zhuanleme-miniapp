page {
  background: #f3f3f3;
  color: #1a1a1a;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border: 1px solid #e6e6e6;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.subtle {
  color: #7d7d7d;
  font-size: 24rpx;
}

.accent {
  color: #e0a800;
}

.btn-primary {
  background: #111111;
  color: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 16rpx;
}
