@import "../../app.wxss";
.brand { margin-bottom: 16rpx; }
.metrics { display:grid; grid-template-columns: 1fr 1fr; gap: 8rpx; margin: 12rpx 0; font-size: 24rpx; }
.status-grid { display:flex; flex-wrap:wrap; gap: 12rpx; margin-top: 12rpx; }
.status-item { padding: 12rpx 18rpx; border:1px solid #ddd; border-radius: 20rpx; font-size:24rpx; }
.status-item.active { background:#111; color:#f7c948; border-color:#111; }
.quicks { display:flex; gap: 12rpx; }
.btn-secondary { flex:1; background:#fff; border:1px solid #111; color:#111; }
.overview .mini-grid { display:grid; grid-template-columns:1fr 1fr; gap:12rpx; }
.overview .mini-grid view { background:#fafafa; padding:12rpx; border-radius:12rpx; white-space: pre-line; }
.overview text { display:block; margin-top:6rpx; font-weight:600; }
.popup-mask { position:fixed; inset:0; background:rgba(0,0,0,.45); display:flex; align-items:flex-end; }
.popup { width:100%; background:#fff; border-radius: 24rpx 24rpx 0 0; padding: 24rpx; }
.picker { padding:16rpx; background:#f6f6f6; border-radius:10rpx; margin: 12rpx 0; }
.expense-row { margin-top: 8rpx; }
.roast { margin-top:10rpx; color:#666; }
