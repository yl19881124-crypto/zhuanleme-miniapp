@import "../../app.wxss";

.home-page { padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); box-sizing: border-box; }
.brand-bar { height: 88rpx; display:flex; align-items:center; justify-content:space-between; border-bottom:4rpx solid #111111; margin-bottom: 20rpx; }
.brand-name { font-size: 40rpx; font-weight: 900; }
.privacy-toggle { background:#FFFFFF; }

.battle-card { padding: 0; overflow: hidden; margin-bottom: 22rpx; }
.battle-head { background: #FFD400; padding: 20rpx 24rpx; border-bottom: 4rpx solid #111111; display:flex; align-items:center; justify-content:space-between; }
.battle-title { font-size: 40rpx; font-weight: 900; }
.battle-icon { font-size: 34rpx; }
.battle-body { padding: 24rpx; display:flex; flex-direction:column; align-items:center; gap: 16rpx; }
.battle-money { font-size: 64rpx; font-weight: 900; line-height: 1.1; }
.battle-pill { background:#FFFFFF; max-width: 100%; }

.status-grid { display:grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-bottom: 22rpx; }
.status-item { background: #FFFFFF; border:4rpx solid #111111; border-radius: 20rpx; height: 160rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; box-sizing:border-box; gap: 8rpx; }
.status-item.active { background: #FFD400; box-shadow: 6rpx 6rpx 0 #111111; }
.status-icon { font-size: 34rpx; line-height: 1; }
.status-text { font-size: 30rpx; font-weight: 800; line-height: 1.1; }

.progress-card { margin-bottom: 22rpx; }
.progress-top { display:flex; align-items:center; justify-content:space-between; margin-bottom: 18rpx; }
.progress-label { margin-bottom: 10rpx; font-weight: 700; }
.progress-track { border:4rpx solid #111111; border-radius: 999rpx; height: 48rpx; background: #F1F1F1; overflow:hidden; }
.progress-fill { height: 100%; background: #FFD400; }

.duo-cards { display:flex; gap: 16rpx; margin-bottom: 26rpx; }
.duo-item { flex: 1; min-height: 180rpx; display:flex; flex-direction:column; justify-content:space-between; }
.duo-title { font-size: 30rpx; font-weight: 900; }
.duo-value { font-size: 52rpx; font-weight: 900; line-height: 1.15; }
.danger-card .duo-title, .danger-card .duo-value { color: #C8191E; }
.gain-card .duo-title { color: #756800; }
.gain-card .duo-value { color: #111111; }

.home-actions { width: 100%; display: flex; flex-direction: column; gap: 20rpx; margin-top: 24rpx; box-sizing: border-box; }
.home-action-btn { width: 100%; height: 88rpx; box-sizing: border-box; display: flex; align-items: center; justify-content: center; border: 4rpx solid #111111; border-radius: 18rpx; box-shadow: 6rpx 6rpx 0 #111111; font-size: 30rpx; font-weight: 900; padding: 0; margin: 0; }
.primary-action { background: #FFD400; color: #111111; }
.secondary-action { background: #FFFFFF; color: #111111; }

.popup-mask { position:fixed; inset:0; background:rgba(0,0,0,.45); display:flex; align-items:flex-end; z-index:9999; }
.popup { width:100%; border-radius: 24rpx 24rpx 0 0; padding: 24rpx; background:#FFFFFF; }
.field { margin-top: 14rpx; }
.money-input-wrap { height: 84rpx; border:3rpx solid #111111; border-radius: 14rpx; background:#F1F1F1; display:flex; align-items:center; padding:0 16rpx; }
.currency { font-size: 30rpx; margin-right: 8rpx; color:#111111; }
.popup-input { height: 84rpx; border:3rpx solid #111111; border-radius: 14rpx; background:#F1F1F1; padding:0 16rpx; font-size: 28rpx; }
.money-input-wrap .popup-input { flex:1; border:none; background:transparent; padding:0; }
.picker { height: 84rpx; border:3rpx solid #111111; border-radius:14rpx; background:#F1F1F1; display:flex; align-items:center; padding:0 16rpx; }
.expense-actions {
  display: flex;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
  margin-top: 24rpx;
}

.expense-action-btn {
  flex: 1;
  height: 88rpx;
  min-height: 88rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  line-height: 1;
  border: 4rpx solid #111111;
  border-radius: 18rpx;
  box-shadow: 6rpx 6rpx 0 #111111;
  font-size: 30rpx;
  font-weight: 900;
}

.expense-action-btn::after {
  border: none;
}

.expense-cancel {
  background: #FFFFFF;
  color: #111111;
}

.expense-confirm {
  background: #FFD400;
  color: #111111;
}
