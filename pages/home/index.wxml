<view class="z-page home-page">
  <view class="brand-bar">
    <view class="brand-name">赚了么</view>
    <view class="z-pill privacy-toggle" bindtap="togglePrivacy">{{hideLabel}}</view>
  </view>

  <view class="z-card battle-card">
    <view class="battle-head">
      <view class="battle-title">今日战果</view>
      <view class="battle-icon">💴</view>
    </view>
    <view class="battle-body">
      <view class="battle-money">{{todayIncome}}</view>
      <view class="z-pill battle-pill">{{roastText}}</view>
    </view>
  </view>

  <view class="status-grid">
    <view wx:for="{{statusCards}}" wx:key="value" class="status-item {{currentStatus===item.value?'active':''}}" data-status="{{item.value}}" bindtap="chooseStatus">
      <view class="status-icon">{{item.icon}}</view>
      <view class="status-text">{{item.label}}</view>
    </view>
  </view>

  <view class="z-card progress-card">
    <view class="progress-top">
      <view class="z-section-title">🧍 副本进度</view>
      <view class="z-pill">距下班：{{offWorkCountdown}}</view>
    </view>
    <view class="z-subtle progress-label">已熬 {{workedDuration}}</view>
    <view class="progress-track">
      <view class="progress-fill" style="width: {{progress}}%;"></view>
    </view>
  </view>

  <view class="duo-cards">
    <view class="z-card duo-item danger-card">
      <view class="duo-title">钱包受损</view>
      <view class="duo-value">{{todayExpenseDisplay==='***' ? '***' : ('-¥' + todayExpenseDisplay)}}</view>
    </view>
    <view class="z-card duo-item gain-card">
      <view class="duo-title">回血进度</view>
      <view class="duo-value">{{netIncomeDisplay==='***' ? '***' : ('+¥' + netIncomeDisplay)}}</view>
    </view>
  </view>

  <view class="btn-group actions">
    <button class="z-btn-primary action-btn" bindtap="openExpensePopup">记录消费</button>
    <button class="z-btn-secondary action-btn" bindtap="goSettlement">每日结算</button>
  </view>

  <view wx:if="{{showExpensePopup}}" class="popup-mask" bindtap="closeExpensePopup">
    <view class="popup z-card-flat" catchtap="noop">
      <view class="z-section-title">记一笔消费</view>
      <view class="field">
        <view class="z-subtle">金额</view>
        <view class="money-input-wrap">
          <text class="currency">¥</text>
          <input class="popup-input" placeholder="请输入金额" type="digit" bindinput="onAmount" value="{{form.amount}}" />
        </view>
      </view>
      <view class="field">
        <view class="z-subtle">分类</view>
        <picker mode="selector" range="{{categories}}" bindchange="onCategory">
          <view class="picker">{{form.category}}</view>
        </picker>
      </view>
      <view class="field">
        <view class="z-subtle">备注</view>
        <input class="popup-input" placeholder="选填，比如：冰美式" bindinput="onNote" value="{{form.note}}" />
      </view>
      <view class="popup-actions">
        <button class="z-btn-secondary mini-btn" bindtap="closeExpensePopup">取消</button>
        <button class="z-btn-primary mini-btn" bindtap="addExpense">确认记录</button>
      </view>
    </view>
  </view>
</view>
