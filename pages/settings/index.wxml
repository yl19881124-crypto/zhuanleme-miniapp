<view class="container">
  <view class="card">
    <view class="title">工资与工作规则</view>

    <view class="field">
      <view class="label">月薪</view>
      <view class="salary-wrap"><text class="prefix">¥</text><input class="input salary" type="digit" data-key="monthlySalary" value="{{profile.monthlySalary}}" bindinput="input" /></view>
    </view>

    <view class="field">
      <view class="label">每月工作日</view>
      <input class="input" type="number" data-key="workdaysPerMonth" value="{{profile.workdaysPerMonth}}" bindinput="input" />
    </view>

    <view class="field"><view class="label">上班时间</view><input class="input" data-key="startTime" value="{{profile.startTime}}" bindinput="input"/></view>
    <view class="field"><view class="label">下班时间</view><input class="input" data-key="endTime" value="{{profile.endTime}}" bindinput="input"/></view>
    <view class="field"><view class="label">午休开始</view><input class="input" data-key="lunchStart" value="{{profile.lunchStart}}" bindinput="input"/></view>
    <view class="field"><view class="label">午休结束</view><input class="input" data-key="lunchEnd" value="{{profile.lunchEnd}}" bindinput="input"/></view>
    <view class="item"><text>午休是否计薪</text><switch checked="{{profile.lunchPaid}}" data-key="lunchPaid" bindchange="toggleProfile"/></view>
    <view class="item"><text>周末是否计薪</text><switch checked="{{profile.weekendPaid}}" data-key="weekendPaid" bindchange="toggleProfile"/></view>
    <button class="btn-primary" bindtap="saveProfile">保存设置</button>
  </view>

  <view class="card">
    <view class="title">隐私设置</view>
    <view class="item"><text>首页隐私模式：控制自己看首页时是否隐藏金额</text><switch checked="{{privacy.hideTodayIncome}}" data-key="hideTodayIncome" bindchange="onPrivacyChange"/></view>
    <view class="item"><text>分享脱敏：海报默认不展示真实收入</text><switch checked="{{privacy.maskOnShare}}" data-key="maskOnShare" bindchange="onPrivacyChange"/></view>
    <view class="subtle">默认你自己看真实金额，分享时再脱敏，爽点和安全都保住。</view>
  </view>

  <view class="card">
    <view class="title">数据管理</view>
    <button class="btn-secondary" bindtap="clearToday">清空今日记录</button>
    <button class="btn-secondary" bindtap="resetAll">重置所有设置</button>
    <button class="btn-secondary" bindtap="exportData">导出本地数据（占位）</button>
  </view>
</view>
