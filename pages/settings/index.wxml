<view class="settings-page">
  <view class="header-block">
    <view class="page-title">配置</view>
    <view class="page-subtitle">调整地牢规则，你的战利品取决于此。</view>
  </view>

  <view class="module-card loot-card">
    <view class="chip chip-yellow">战利品规则</view>

    <view class="form-item">
      <view class="form-label">月薪（幻觉）</view>
      <view class="salary-input-wrap">
        <text class="currency">¥</text>
        <input
          class="form-input salary-input"
          type="digit"
          placeholder="输入你那微薄的薪水..."
          placeholder-class="input-placeholder"
          data-key="monthlySalary"
          value="{{profile.monthlySalary}}"
          bindinput="input"
        />
      </view>
    </view>

    <view class="grid-two">
      <view class="form-item compact">
        <view class="form-label">每月工作天数</view>
        <input class="form-input" type="number" data-key="workdaysPerMonth" value="{{profile.workdaysPerMonth}}" bindinput="input" />
      </view>
      <view class="form-item compact">
        <view class="form-label">每日工时（小时）</view>
        <view class="form-input readonly-input">按上下班与午休自动计算</view>
      </view>
    </view>

    <view class="grid-two">
      <view class="form-item compact"><view class="form-label">上班时间</view><picker mode="time" value="{{profile.startTime}}" bindchange="onTimeChange" data-field="startTime"><view class="form-input time-picker-field">{{profile.startTime || '请选择上班时间'}}</view></picker></view>
      <view class="form-item compact"><view class="form-label">下班时间</view><picker mode="time" value="{{profile.endTime}}" bindchange="onTimeChange" data-field="endTime"><view class="form-input time-picker-field">{{profile.endTime || '请选择下班时间'}}</view></picker></view>
    </view>

    <view class="grid-two">
      <view class="form-item compact"><view class="form-label">午休开始</view><picker mode="time" value="{{profile.lunchStart}}" bindchange="onTimeChange" data-field="lunchStart"><view class="form-input time-picker-field">{{profile.lunchStart || '请选择午休开始'}}</view></picker></view>
      <view class="form-item compact"><view class="form-label">午休结束</view><picker mode="time" value="{{profile.lunchEnd}}" bindchange="onTimeChange" data-field="lunchEnd"><view class="form-input time-picker-field">{{profile.lunchEnd || '请选择午休结束'}}</view></picker></view>
    </view>

    <view class="switch-row dashed-top">
      <view class="switch-copy">
        <view class="switch-title">午休是否计薪</view>
        <view class="switch-desc">吃饭也算工伤吗？（并不）</view>
      </view>
      <switch checked="{{profile.lunchPaid}}" data-key="lunchPaid" bindchange="toggleProfile" color="#f5d300" />
    </view>

    <view class="switch-row">
      <view class="switch-copy">
        <view class="switch-title">周末是否计薪</view>
        <view class="switch-desc">周末副本是否计入战利品。</view>
      </view>
      <switch checked="{{profile.weekendPaid}}" data-key="weekendPaid" bindchange="toggleProfile" color="#f5d300" />
    </view>

    <view class="save-btn" bindtap="saveProfile">保存设置</view>
  </view>

  <view class="module-card">
    <view class="chip">隐身模式</view>

    <view class="privacy-item">
      <view class="privacy-icon">◍</view>
      <view class="privacy-copy">
        <view class="privacy-title">首页隐藏模式</view>
        <view class="privacy-desc">当老板路过时隐藏精确收益。</view>
      </view>
      <switch checked="{{privacy.hideTodayIncome}}" data-key="hideTodayIncome" bindchange="onPrivacyChange" color="#f5d300" />
    </view>

    <view class="privacy-item no-border">
      <view class="privacy-icon">※</view>
      <view class="privacy-copy">
        <view class="privacy-title">数据脱敏</view>
        <view class="privacy-desc">显示“很多”而不是具体数字。</view>
      </view>
      <switch checked="{{privacy.maskOnShare}}" data-key="maskOnShare" bindchange="onPrivacyChange" color="#f5d300" />
    </view>
  </view>

  <view class="module-card danger-card">
    <view class="module-title">危险区域</view>
    <view class="danger-list">
      <view class="danger-item" bindtap="clearToday">
        <text class="danger-text">清空今日战利品</text>
        <text class="arrow">›</text>
      </view>
      <view class="danger-item alert" bindtap="resetAll">
        <text class="danger-text danger-red">重置所有设置</text>
        <text class="arrow danger-red">›</text>
      </view>
    </view>
  </view>
</view>
