<view class="container">
  <view class="card">
    <view class="title">我的设置</view>
    <view class="subtle">隐私优先，本地优先。</view>
    <view class="item"><text>隐藏薪资</text><switch checked="{{privacy.hideSalary}}" data-key="hideSalary" bindchange="onPrivacyChange"/></view>
    <view class="item"><text>隐藏今日已赚</text><switch checked="{{privacy.hideTodayIncome}}" data-key="hideTodayIncome" bindchange="onPrivacyChange"/></view>
    <view class="item"><text>隐藏净收入</text><switch checked="{{privacy.hideNetIncome}}" data-key="hideNetIncome" bindchange="onPrivacyChange"/></view>
    <view class="item"><text>分享海报脱敏</text><switch checked="{{privacy.maskOnShare}}" data-key="maskOnShare" bindchange="onPrivacyChange"/></view>
  </view>
</view>
