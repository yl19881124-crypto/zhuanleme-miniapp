@import "../../app.wxss";
.field { margin-bottom: 14rpx; }
.label { font-size: 24rpx; color:#555; margin-bottom: 8rpx; }
.salary-wrap { display:flex; align-items:center; background:#f7f7f7; border-radius: 10rpx; padding: 0 14rpx; }
.prefix { font-size: 28rpx; color:#444; margin-right: 6rpx; }
.salary { flex:1; background: transparent; }
.input { width:100%; background:#f7f7f7; border-radius:10rpx; padding:16rpx; }
.item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1px solid #eee; }
.btn-secondary { margin-top: 12rpx; }
