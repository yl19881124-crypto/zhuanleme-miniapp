@import "../../app.wxss";

.field { margin-bottom: 14rpx; }
.label { font-size: 24rpx; color:#555; margin-bottom: 8rpx; }
.salary-wrap { display:flex; align-items:center; background:#f7f8fa; border:1px solid #e1e6ef; border-radius: 12rpx; padding: 0 14rpx; }
.prefix { font-size: 28rpx; color:#444; margin-right: 6rpx; }
.salary { flex:1; background: transparent; border:none; }
.item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1px solid #eef1f5; gap: 16rpx; }
.btn-secondary, .btn-primary { margin-top: 12rpx; }
