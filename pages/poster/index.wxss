.container { padding: 24rpx; background: #f5f5f5; min-height: 100vh; box-sizing: border-box; }
.poster-wrap { background: #fff; border-radius: 20rpx; padding: 16rpx; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08); }
.poster-canvas { width: 702rpx; height: 1104rpx; border-radius: 12rpx; }
.actions { margin-top: 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.btn { border-radius: 16rpx; font-size: 30rpx; }
.btn-primary { background: #111; color: #ffd23f; }
.btn-secondary { background: #ffd23f; color: #111; }
.btn-ghost { background: #fff; color: #333; border: 1rpx solid #ddd; }
