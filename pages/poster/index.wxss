.container {
  min-height: 100vh;
  padding: 32rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

.panel {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: #555555;
}

.actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
}

.btn-primary {
  background: #111111;
  color: #ffffff;
}

.btn-secondary {
  background: #ffffff;
  color: #111111;
  border: 1px solid #d9d9d9;
}
