@import "../../app.wxss";

.settlement-page {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card,
.judge-card,
.action-btn {
  border: 4rpx solid #111111;
  border-radius: 24rpx;
  box-shadow: 8rpx 8rpx 0 #111111;
}

.card {
  background: #FFFFFF;
  margin-bottom: 22rpx;
  padding: 24rpx;
}

.dungeon-report {
  text-align: center;
  padding-top: 22rpx;
  padding-bottom: 22rpx;
}

.report-subtitle { font-size: 30rpx; font-weight: 800; color: #6b5b14; }
.report-title { font-size: 50rpx; font-weight: 900; line-height: 1.2; margin: 10rpx 0 18rpx; }
.status-pill {
  display: inline-block;
  background: #FFD400;
  border: 3rpx solid #111111;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.section-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.section-title { font-size: 34rpx; font-weight: 900; }
.level-tag { font-size: 24rpx; font-weight: 700; color: #3b3312; }

.loot-grid { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.loot-small {
  flex: 1;
  border: 4rpx solid #111111;
  border-radius: 20rpx;
  background: #F5F5F5;
  padding: 18rpx;
  text-align: center;
}
.loot-small.expense { background: #FFEAEA; }
.loot-label { font-size: 26rpx; font-weight: 700; }
.loot-value { font-size: 42rpx; font-weight: 900; margin-top: 8rpx; color: #5a4a08; line-height: 1.2; }
.expense .loot-value { color: #8d1111; }
.loot-net {
  border: 4rpx solid #111111;
  border-radius: 20rpx;
  background: #FFD400;
  padding: 20rpx;
  text-align: center;
}
.loot-net-value { font-size: 54rpx; font-weight: 900; margin-top: 8rpx; color: #5a4a08; line-height: 1.2; }

.behavior-item { margin-top: 24rpx; }
.behavior-row { display: flex; justify-content: space-between; font-size: 26rpx; font-weight: 700; margin-bottom: 10rpx; }
.progress-track {
  height: 20rpx;
  border: 4rpx solid #111111;
  border-radius: 999rpx;
  background: #DFDFDF;
  overflow: hidden;
  margin: 0 4rpx;
}
.progress-fill { height: 100%; border-radius: 999rpx; }
.progress-fill.warn { background: #6A6A6A; }
.progress-fill.hot { background: #B72020; }
.progress-fill.good { background: #807000; }

.mood-card {
  display: flex;
  align-items: stretch;
  min-height: 170rpx;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
}
.mood-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.mood-col-left { padding-right: 28rpx; }
.mood-col-right { padding-left: 36rpx; }
.mood-divider {
  width: 4rpx;
  height: 96rpx;
  background: #111111;
  align-self: center;
  flex-shrink: 0;
}
.mood-label { font-size: 26rpx; font-weight: 800; color: #111111; line-height: 1.2; margin-bottom: 14rpx; }
.mood-main { font-size: 46rpx; font-weight: 900; line-height: 1.1; }
.mood-danger { color: #C8191E; }
.fish-grade {
  color: #756800;
}
.mood-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #666666;
  line-height: 1.2;
}

.judge-card {
  background: #5d5203;
  color: #FFFFFF;
  padding: 24rpx;
  margin-bottom: 22rpx;
  text-align: center;
}
.judge-title { font-size: 34rpx; font-weight: 900; }
.judge-result { margin-top: 12rpx; font-size: 50rpx; font-weight: 900; line-height: 1.2; }

.actions { margin-top: 18rpx; }
.action-btn {
  height: 88rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
  margin-bottom: 20rpx;
}
.action-btn.primary { background: #FFD400; color: #111111; }
.action-btn.secondary { background: #FFFFFF; color: #111111; }
