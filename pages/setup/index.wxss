page {
  background: #f7f7f7;
}

.setup-page {
  padding: 28rpx 24rpx 40rpx;
}

.hero {
  margin: 12rpx 8rpx 18rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #111;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.setup-card {
  margin: 24rpx 0;
  padding: 32rpx;
  background: #fff;
  border: 4rpx solid #111;
  border-radius: 24rpx;
  box-shadow: 8rpx 8rpx 0 #111;
}

.card-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #111;
  background: #ffd400;
  border: 3rpx solid #111;
  border-radius: 999rpx;
}

.field-label {
  font-size: 30rpx;
  font-weight: 800;
  color: #111;
}

.salary-input-wrap {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  width: 100%;
  height: 88rpx;
  border: 4rpx solid #111;
  border-radius: 16rpx;
  background: #fff;
  box-sizing: border-box;
}

.salary-prefix {
  width: 72rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 900;
  color: #111;
}

.salary-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #111;
}

.salary-placeholder {
  color: #9a9a9a;
}

.field-tip {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #666;
}

.start-btn {
  margin-top: 28rpx;
  height: 88rpx;
  border: 4rpx solid #111;
  border-radius: 18rpx;
  background: #ffd400;
  box-shadow: 6rpx 6rpx 0 #111;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
  color: #111;
}

.footer-tip {
  margin-top: 20rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #666;
}
