.custom-tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(92rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #FFFFFF;
  border-top: 2rpx solid #E5E5E5;
  display: flex;
  align-items: center;
  z-index: 999;
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-inner {
  min-width: 70rpx;
  height: 64rpx;
  padding: 2rpx 8rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: #3A3420;
}

.tab-inner.active {
  background: #FFD400;
  border: 4rpx solid #111111;
  box-shadow: 3rpx 3rpx 0 #111111;
  color: #111111;
}

.tab-icon {
  font-size: 26rpx;
  line-height: 1;
  margin-bottom: 2rpx;
}

.tab-text {
  font-size: 18rpx;
  line-height: 1;
  font-weight: 800;
}
